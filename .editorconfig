# Editor config for consistent code style
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.kt]
indent_size = 4
max_line_length = 160

[*.md]
trim_trailing_whitespace = false
max_line_length = 120

[*.properties]
trim_trailing_whitespace = true

[*.xml]
trim_trailing_whitespace = true
max_line_length = 200
